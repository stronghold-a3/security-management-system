# Copy this file to .env.development, .env.staging, or .env.production
# and fill in the actual values.

NODE_ENV=
APP_NAME=
APP_VERSION=
API_BASE_URL=

PORT=8080
HOST=0.0.0.0
VITE_API_BASE_URL=

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

JWT_SECRET=
JWT_EXPIRY=24h
REFRESH_TOKEN_EXPIRY=7d
SESSION_SECRET=

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

CORS_ALLOWED_ORIGINS=
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,PATCH,OPTIONS
CORS_ALLOW_CREDENTIALS=true

CSP_ENABLE=true
CSP_REPORT_URI=

DATABASE_URL=
DB_CONNECTION_POOL_MIN=5
DB_CONNECTION_POOL_MAX=20
DB_SSL_MODE=require

REDIS_URL=
REDIS_PASSWORD=
REDIS_TLS=true
CACHE_TTL_SECONDS=3600
SESSION_STORE=redis
REDIS_API_KEY=

STORAGE_BUCKET_NAME=
STORAGE_BUCKET_PUBLIC_URL=
MAX_FILE_SIZE_MB=50
ALLOWED_FILE_TYPES=pdf,doc,docx,xls,xlsx,jpg,jpeg,png,gif

LOG_LEVEL=info
LOG_FORMAT=json
SENTRY_DSN=
SENTRY_ENVIRONMENT=
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.1

ENABLE_GOOGLE_ANALYTICS=false
GOOGLE_ANALYTICS_ID=
ENABLE_PERFORMANCE_MONITORING=true
PERFORMANCE_API_ENDPOINT=

FEATURE_TWILIO_SMS=false
FEATURE_VIBER_INTEGRATION=false
FEATURE_RADIO_MESH=true
FEATURE_OFFLINE_MODE=true
FEATURE_ADVANCED_ANALYTICS=true
FEATURE_BULK_OPERATIONS=true

TWILIO_ACCOUNT_SID=
TWILIO_AUTHTOKEN=
SMS_SENDER_ID=

VIBER_API_URL=
VIBER_BOT_NAME=
VIBER_ACCOUNT_TOKEN=

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=

DOLE_REGISTRATION_NUMBER=
ORGANIZATION_LEGAL_NAME=
ORGANIZATION_TAX_ID=
ORGANIZATION_LOCATION=
