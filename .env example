# ============================================================================
# Security Management System - Production Environment Configuration
# ============================================================================
# IMPORTANT: This file must be secured and never committed to version control
# Use individual .env files for different environments (dev, staging, prod)
# ============================================================================

# ============================================================================
# APPLICATION ENVIRONMENT & BASE CONFIGURATION
# ============================================================================
NODE_ENV=production
APP_NAME=Security Management System
APP_VERSION=1.0.0
API_BASE_URL=https://api.strongholda3.com

# ============================================================================
# SERVER & NETWORK CONFIGURATION
# ============================================================================
PORT=8080
HOST=0.0.0.0
VITE_API_BASE_URL=https://api.strongholda3.com

# ============================================================================
# SUPABASE CONFIGURATION
# ============================================================================
VITE_SUPABASE_URL=https://fhwhqoiucfxmfsclianh.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_public_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ============================================================================
# SECURITY & AUTHENTICATION
# ============================================================================
# Session & Token Configuration
JWT_SECRET=your_secure_jwt_secret_key_minimum_32_chars
JWT_EXPIRY=24h
REFRESH_TOKEN_EXPIRY=7d
SESSION_SECRET=your_secure_session_secret_minimum_32_chars

# API Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# CORS Configuration
CORS_ALLOWED_ORIGINS=https://strongholda3.com,https://www.strongholda3.com,https://app.strongholda3.com
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,PATCH,OPTIONS
CORS_ALLOW_CREDENTIALS=true

# Content Security Policy
CSP_ENABLE=true
CSP_REPORT_URI=https://api.strongholda3.com/csp-report

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
DATABASE_URL=postgresql://user:password@db.strongholda3.com:5432/security_db
DB_CONNECTION_POOL_MIN=5
DB_CONNECTION_POOL_MAX=20
DB_SSL_MODE=require

# ============================================================================
# CACHE & SESSION STORE
# ============================================================================
REDIS_URL=redis://cache.strongholda3.com:6379
REDIS_PASSWORD=your_redis_password_here
REDIS_TLS=true
CACHE_TTL_SECONDS=3600
SESSION_STORE=redis

# ============================================================================
# FILE STORAGE & CDN
# ============================================================================
# Supabase Storage Bucket
STORAGE_BUCKET_NAME=sop-files
STORAGE_BUCKET_PUBLIC_URL=https://fhwhqoiucfxmfsclianh.supabase.co/storage/v1/object/public/sop-files

# File Upload Limits
MAX_FILE_SIZE_MB=50
ALLOWED_FILE_TYPES=pdf,doc,docx,xls,xlsx,jpg,jpeg,png,gif

# ============================================================================
# LOGGING & MONITORING
# ============================================================================
LOG_LEVEL=info
LOG_FORMAT=json
SENTRY_DSN=https://your_sentry_dsn_key@sentry.io/your_project_id
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.1

# ============================================================================
# ANALYTICS & PERFORMANCE
# ============================================================================
ENABLE_GOOGLE_ANALYTICS=true
GOOGLE_ANALYTICS_ID=G-your_ga_id_here
ENABLE_PERFORMANCE_MONITORING=true
PERFORMANCE_API_ENDPOINT=https://api.strongholda3.com/metrics

# ============================================================================
# FEATURE FLAGS
# ============================================================================
FEATURE_SMS_GATEWAY=true
FEATURE_VIBER_INTEGRATION=true
FEATURE_RADIO_MESH=true
FEATURE_OFFLINE_MODE=true
FEATURE_ADVANCED_ANALYTICS=true
FEATURE_BULK_OPERATIONS=true

# ============================================================================
# EXTERNAL INTEGRATIONS
# ============================================================================
# SMS Gateway Configuration
SMS_GATEWAY_API_KEY=your_sms_gateway_api_key_here
SMS_GATEWAY_ENDPOINT=https://api.smsgateway.com/v1/send
SMS_SENDER_ID=STRONGHOLD

# Viber Integration
VIBER_API_URL=https://chatapi.viber.com
VIBER_BOT_NAME=Stronghold A3 SMS
VIBER_ACCOUNT_TOKEN=your_viber_account_token_here

# Email Configuration
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=your_sendgrid_api_key_here
SMTP_FROM_EMAIL=noreply@strongholda3.com
SMTP_FROM_NAME=Stronghold A3 Security

# ============================================================================
# COMPLIANCE & DOLE CERTIFICATIONS
# ============================================================================
DOLE_REGISTRATION_NUMBER=DO-174-XXXXX
ORGANIZATION_LEGAL_NAME=Stronghold A3 Security Agency
ORGANIZATION_TAX_ID=123-456-789-000
ORGANIZATION_LOCATION=Eastern Visayas, Philippines

# ============================================================================
# ENVIRONMENT-SPECIFIC OVERRIDES
# ============================================================================
# Use these to override defaults in specific environments
# STAGING_OVERRIDE_RATE_LIMIT=true
# STAGING_DEBUG_MODE=false
